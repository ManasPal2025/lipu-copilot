{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "LIPU Backend - FastAPI Application",
  "scripts": {
    "dev": "uvicorn app.main:app --reload --port 8000",
    "start": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "lint": "flake8 app tests",
    "type-check": "mypy app",
    "format": "black app tests",
    "format:check": "black --check app tests",
    "test": "pytest",
    "test:watch": "pytest --watch",
    "test:coverage": "pytest --cov=app --cov-report=html",
    "migrate": "alembic upgrade head",
    "migrate:create": "alembic revision --autogenerate -m",
    "seed": "python scripts/seed_data.py",
    "clean": "find . -type f -name '*.pyc' -delete && find . -type d -name __pycache__ -delete"
  }
}
