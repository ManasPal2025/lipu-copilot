APP_NAME=LIPU API
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Use port 5433 when Postgres runs via docker-compose (host mapping)
DATABASE_URL=postgresql+asyncpg://lipu_user:lipu_password_dev@localhost:5433/lipu_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false

# Use port 6380 when Redis runs via docker-compose (host mapping)
REDIS_URL=redis://localhost:6380/0
REDIS_CACHE_TTL=3600
REDIS_DECODE_RESPONSES=true
REDIS_HEALTH_CHECK_INTERVAL=30

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
ALLOWED_HOSTS=localhost,127.0.0.1

LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-ID
SENTRY_DSN=

