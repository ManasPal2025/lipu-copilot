# Public runtime (embedded at build time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# RAG chatbot — persistent Python server (run: cd lipu-platform/rag && python server.py)
RAG_SERVER_URL=http://127.0.0.1:8100
# RAG_ROOT=F:/Lipu_copilot/lipu-platform/rag

# AI feature flags (Next.js /api/chat)
# Local default: AI_ENABLED=true, AI_MODE=retrieval (when unset in development)
# Production default: AI_ENABLED=false (when unset on Vercel)
AI_ENABLED=true
AI_MODE=retrieval

# Production example:
# NEXT_PUBLIC_API_BASE_URL=https://api.lipu.com/api/v1
# NEXT_PUBLIC_SITE_URL=https://www.lipu.com
# AI_ENABLED=true
# AI_MODE=retrieval
# RAG_SERVER_URL=https://your-railway-rag-service.up.railway.app
