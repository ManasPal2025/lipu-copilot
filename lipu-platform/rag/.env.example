# Optional — only required when AI_MODE = "gemini" in rag/config.py
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# ── Railway (RAG server) ─────────────────────────────────────────────────
# PORT is set automatically by Railway — do not set manually.
# Mount volume at /app/data/chroma (see RAILWAY.md).
# HF_HOME=/app/.cache/huggingface  # optional model cache volume
# HF_TOKEN=hf_...                  # optional faster Hugging Face downloads
# RAG_RETRIEVER_DEBUG=1

# ── Vercel (Next.js) — points to Railway RAG server ───────────────────────
#RAG_SERVER_URL=https://your-service.up.railway.app

# Optional overrides
# GEMINI_API_KEY=your-google-ai-api-key
# GEMINI_MODEL=gemini-2.0-flash
