# Optional — only required when AI_MODE = "gemini" in rag/config.py
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
# Persistent RAG server (recommended for dev — loads model once)
#RAG_SERVER_URL=http://127.0.0.1:8100

# Optional overrides
# GEMINI_API_KEY=your-google-ai-api-key
# GEMINI_MODEL=gemini-2.0-flash

# Retriever debug — logs [RETRIEVER] block to stderr (collection, top-10 matches, filter decisions)
# RAG_RETRIEVER_DEBUG=1
